{
    "name": "botman/line-app",
    "description": "Minimal BotMan app wired to a local LINE driver",
    "type": "project",
    "require": {
        "php": "^7.4 || ^8.0",
        "botman/botman": "^2.0",
        "gundamew/botman-driver-line": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../botman-driver-line",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "serve": "php -S 127.0.0.1:8000 -t public"
    }
}
