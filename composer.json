{
    "name": "botman/line-app",
    "description": "Minimal BotMan app wired to a local LINE driver",
    "type": "project",
    "require": {
        "php": "^8.4",
        "botman/botman": "^2.0",
        "gundamew/botman-driver-line": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../botman-driver-line",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "audit": {
            "ignore": ["PKSA-z3gr-8qht-p93v"]
        }
    },
    "scripts": {
        "serve": "php84 -S 127.0.0.1:8000 -t public",
        "test": "php84 vendor/bin/phpunit",
        "test-coverage": "php84 vendor/bin/phpunit --coverage-html build/coverage"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mikey179/vfsstream": "^1.6"
    }
}
